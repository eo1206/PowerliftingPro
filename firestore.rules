rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function autenticado() {
      return request.auth != null;
    }

    match /usuarios/{uid} {
      allow read, create, update: if autenticado() && request.auth.uid == uid;
      allow delete: if false;

      match /{subcoleccion}/{documento} {
        allow read, write: if autenticado() && request.auth.uid == uid;
      }
    }

    match /ranking/{uid} {
      allow read: if autenticado();
      allow create, update: if autenticado()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if autenticado() && request.auth.uid == uid;
    }
  }
}
